# See https://docs.github.com/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# Compiled output
/dist
/tmp
/out-tsc
/bazel-out

# Node
/node_modules
npm-debug.log
yarn-error.log

# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/*

# Python
__pycache__/
*.pyc

# Miscellaneous
/.angular/cache
.sass-cache/
/connect.lock
/coverage
/libpeerconnection.log
testem.log
/typings
__screenshots__/

# Model weights / checkpoints
checkpoints/

# System files
.DS_Store
Thumbs.db
._*
*.dmg
release/*
*.plist
dist/*
.vscode/*
CLAUDE.md
.claude/
.editorconfig
resources/bin/*
summary-*.json
*.ttf

# conda-pack tarballs (multi-GB build artifacts; ymls in packaging/env are committed)
packaging/artifacts/

# staged packaging resources (rebuilt by packaging/stage-resources.js)
resources/e2a/
resources/e2a-env.tar.gz
# ExFAT-orphaned snapshot dirs that couldn't be deleted (renamed aside)
resources/*.stuck-*
resources/.e2a-stuck-*
# persistent seed staging cache (default voice checkpoint for --seed builds)
packaging/.seed-cache/
