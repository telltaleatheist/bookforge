{
  "name": "bookforge-app",
  "productName": "BookForge",
  "version": "0.1.7",
  "description": "BookForge - Audiobook production pipeline",
  "main": "dist/electron/launcher/bootstrap.js",
  "private": true,
  "scripts": {
    "ng": "ng",
    "deploy:iphone": "bash mobile/deploy-iphone.sh",
    "start": "npm run electron:dev",
    "start:web": "ng serve --port 4250",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "build:bookshelf": "ng build bookshelf-app --configuration production",
    "copy:plugin-assets": "node -e \"require('fs').cpSync('electron/plugins/builtin','dist/electron/plugins/builtin',{recursive:true,filter:(s)=>!s.endsWith('.ts')})\"",
    "build:electron": "npx tsc -p tsconfig.electron.json && npx shx cp -r electron/prompts dist/electron/ && npm run build:bookshelf && npx shx mkdir -p dist/electron/scripts && npx shx cp electron/scripts/xtts_stream.py dist/electron/scripts/ && npx shx cp electron/scripts/orpheus_stream.py dist/electron/scripts/ && npx shx cp electron/scripts/orpheus_download.py dist/electron/scripts/ && npx shx cp electron/scripts/whisper_download.py dist/electron/scripts/ && npx shx cp electron/scripts/transcribe_audiobook.py dist/electron/scripts/ && npx shx mkdir -p dist/electron/python && npx shx cp electron/python/env_diagnostics.py dist/electron/python/ && npm run copy:plugin-assets && node packaging/stamp-build.js",
    "electron:dev": "npm run build:electron && concurrently \"ng serve --port 4250\" \"wait-on http://localhost:4250 && electron . --max-old-space-size=8192\"",
    "electron:build": "npm run build:electron && npm run build:prod && node packaging/run-builder.js",
    "build:code-bundle": "node packaging/build-code-bundle.js",
    "build:starter-library": "node packaging/build-starter-library.js",
    "publish:code": "node packaging/publish-release.js",
    "publish:component": "node packaging/publish-release.js --component",
    "publish:starter": "node packaging/publish-release.js --starter",
    "version:bump": "npm version patch --no-git-tag-version",
    "version:bump:minor": "npm version minor --no-git-tag-version",
    "publish:mac": "npm run package:mac && node packaging/publish-app.js --mac",
    "publish:win-x64": "npm run package:win-x64 && node packaging/publish-app.js --win",
    "publish:extension": "node packaging/publish-app.js --extension",
    "publish:app:dry:mac": "node packaging/publish-app.js --mac --dry-run",
    "publish:app:dry:win": "node packaging/publish-app.js --win --dry-run",
    "publish:app:dry:extension": "node packaging/publish-app.js --extension --dry-run",
    "stage:packaging": "node packaging/stage-resources.js",
    "stage:packaging:seed": "node packaging/stage-resources.js --seed",
    "stage:packaging:offline": "node packaging/stage-resources.js --models",
    "package:mac": "npm run download:mupdf && npm run download:llama && npm run stage:packaging:seed && npm run build:electron && npm run build:prod && node packaging/build-dmg.js --mac && npm run build:code-bundle",
    "package:mac:lean": "npm run download:mupdf && npm run download:llama && npm run stage:packaging && npm run build:electron && npm run build:prod && node packaging/build-dmg.js --mac && npm run build:code-bundle",
    "package:mac:offline": "npm run download:mupdf && npm run download:llama && npm run stage:packaging:offline && npm run build:electron && npm run build:prod && node packaging/build-dmg.js --mac && npm run build:code-bundle",
    "package:win": "npm run download:mupdf && npm run download:llama && npm run stage:packaging:seed && npm run electron:build -- --win && npm run build:code-bundle",
    "package:win-x64": "node packaging/package-win.js",
    "package:win-inno": "node packaging/package-win.js",
    "inno:build": "node packaging/build-inno.js",
    "package:linux": "npm run download:mupdf && npm run electron:build -- --linux",
    "watch": "ng build --watch --configuration development",
    "watch:electron": "npx tsc -p tsconfig.electron.json --watch",
    "test": "ng test",
    "download:mupdf": "node scripts/download-mupdf.js",
    "download:llama": "node scripts/download-llama-cpp.js",
    "postinstall": "npm run download:mupdf || echo 'MuPDF download skipped (run npm run download:mupdf manually if needed)'"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "dependencies": {
    "@angular/cdk": "^21.0.5",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@mozilla/readability": "^0.6.0",
    "@types/cheerio": "^0.22.35",
    "@types/express": "^5.0.6",
    "@types/ws": "^8.18.1",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.2.0",
    "diff": "^8.0.3",
    "epubjs": "^0.3.93",
    "express": "^5.2.1",
    "jsdom": "^28.0.0",
    "mupdf": "^1.27.0",
    "music-metadata": "^11.11.1",
    "node-tesseract-ocr": "^2.2.1",
    "pdf-lib": "^1.17.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.1.0",
    "@angular/build": "^21.0.4",
    "@angular/cli": "^21.0.4",
    "@angular/compiler-cli": "^21.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^20.11.0",
    "@vitejs/plugin-basic-ssl": "^2.1.3",
    "concurrently": "^8.2.0",
    "electron": "^29.0.0",
    "electron-builder": "^24.13.0",
    "http-server": "^14.1.1",
    "shx": "^0.4.0",
    "typescript": "~5.9.2",
    "vite": "^7.3.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.bookforge.app",
    "productName": "BookForge",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "bookforge-icon.png"
    ],
    "asarUnpack": [
      "dist/electron/scripts/**",
      "dist/electron/python/**",
      "node_modules/**"
    ],
    "icon": "bookforge-icon.png",
    "compression": "store",
    "nsis": {
      "include": "packaging/installer.nsh"
    },
    "dmg": {
      "format": "ULFO",
      "writeUpdateInfo": false
    },
    "mac": {
      "category": "public.app-category.productivity",
      "identity": null,
      "target": "dmg",
      "icon": "bookforge-icon.png",
      "extraResources": [
        {
          "from": "resources/bin/mutool-${arch}",
          "to": "bin/mutool-${arch}"
        },
        {
          "from": "resources/bin/llama-server-${arch}",
          "to": "bin/llama-server-${arch}"
        },
        {
          "from": "resources/bin",
          "to": "bin",
          "filter": [
            "*.dylib"
          ]
        },
        {
          "from": "resources/e2a",
          "to": "e2a"
        },
        {
          "from": "packaging/seed-books",
          "to": "seed-books"
        }
      ]
    },
    "win": {
      "target": "nsis",
      "icon": "bookforge-icon.png",
      "extraResources": [
        {
          "from": "resources/bin/mutool.exe",
          "to": "bin/mutool.exe"
        },
        {
          "from": "resources/bin/llama-server.exe",
          "to": "bin/llama-server.exe"
        },
        {
          "from": "resources/bin",
          "to": "bin",
          "filter": [
            "*.dll"
          ]
        },
        {
          "from": "resources/e2a",
          "to": "e2a"
        },
        {
          "from": "packaging/seed-books",
          "to": "seed-books"
        }
      ]
    },
    "linux": {
      "target": "AppImage",
      "icon": "bookforge-icon.png",
      "extraResources": [
        {
          "from": "resources/bin/mutool-linux",
          "to": "bin/mutool-linux"
        }
      ]
    }
  }
}
